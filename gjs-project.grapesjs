ure"}]},{"tagName":"p","type":"text","classes":["wish-text"],"attributes":{"id":"ikq23v"},"components":[{"type":"textnode","content":"May new places, new stories, and beautiful little surprises find their way to you and make this year unforgettable."}]}]},{"tagName":"article","classes":["wish-card","soft-panel"],"attributes":{"id":"ikjq4s"},"components":[{"type":"text","classes":["wish-icon"],"attributes":{"id":"i1feba"},"components":[{"type":"textnode","content":"♥"}]},{"tagName":"h3","type":"heading","classes":["font-display","wish-title"],"attributes":{"id":"ia4akr"},"components":[{"type":"textnode","content":"Wish of Love"}]},{"tagName":"p","type":"text","classes":["wish-text"],"attributes":{"id":"igq7j3"},"components":[{"type":"textnode","content":"May you always feel deeply loved, intentionally cherished, and gently reminded of how precious you truly are."}]}]},{"tagName":"article","classes":["wish-card","soft-panel"],"attributes":{"id":"i5iso5"},"components":[{"type":"text","classes":["wish-icon"],"attributes":{"id":"i96uai"},"components":[{"type":"textnode","content":"❀"}]},{"tagName":"h3","type":"heading","classes":["font-display","wish-title"],"attributes":{"id":"izmh2g"},"components":[{"type":"textnode","content":"Wish of Calm"}]},{"tagName":"p","type":"text","classes":["wish-text"],"attributes":{"id":"ik2s6g"},"components":[{"type":"textnode","content":"May your days carry peace, your nights carry rest, and your heart always feel safe enough to bloom."}]}]},{"tagName":"article","classes":["wish-card","soft-panel"],"attributes":{"id":"immrhh"},"components":[{"type":"text","classes":["wish-icon"],"attributes":{"id":"idcc6g"},"components":[{"type":"textnode","content":"✦"}]},{"tagName":"h3","type":"heading","classes":["font-display","wish-title"],"attributes":{"id":"i927ql"},"components":[{"type":"textnode","content":"Wish of Success"}]},{"tagName":"p","type":"text","classes":["wish-text"],"attributes":{"id":"isnv0b"},"components":[{"type":"textnode","content":"May your goals become lighter to carry, your confidence become stronger, and your brightest ideas come alive."}]}]},{"tagName":"article","classes":["wish-card","soft-panel"],"attributes":{"id":"ivah5e"},"components":[{"type":"text","classes":["wish-icon"],"attributes":{"id":"iqqfa2"},"components":[{"type":"textnode","content":"🎂"}]},{"tagName":"h3","type":"heading","classes":["font-display","wish-title"],"attributes":{"id":"i273el"},"components":[{"type":"textnode","content":"Birthday Promise"}]},{"tagName":"p","type":"text","classes":["wish-text"],"attributes":{"id":"in3wov"},"components":[{"type":"textnode","content":"And above all, may this birthday remind you that you deserve beautiful effort, meaningful love, and special moments made just for you."}]}]}]}]}]},{"tagName":"section","classes":["section-screen","surprise-bg","surprise-section"],"attributes":{"id":"surprise"},"components":[{"classes":["surprise-decorations","romance-shell"],"attributes":{"id":"ivhlwt"},"components":[{"tagName":"span","type":"text","classes":["sparkle","star","float-spark"],"attributes":{"id":"ivnira"},"components":[{"type":"textnode","content":"✦"}]},{"tagName":"span","type":"text","classes":["sparkle","star","float-spark"],"attributes":{"id":"i050ge"},"components":[{"type":"textnode","content":"✧"}]},{"tagName":"span","type":"text","classes":["sparkle","star","float-spark"],"attributes":{"id":"ik1gow"},"components":[{"type":"textnode","content":"✦"}]},{"tagName":"span","type":"text","classes":["sparkle","star","float-spark"],"attributes":{"id":"ipo6q6"},"components":[{"type":"textnode","content":"✧"}]},{"classes":["backdrop-orb","orb-d"],"attributes":{"id":"i90kbs"}},{"classes":["luxe-ring"],"attributes":{"id":"i1vaor"}},{"classes":["luxe-ring"],"attributes":{"id":"ic1k7l"}},{"tagName":"span","type":"text","classes":["dec-heart"],"attributes":{"id":"ilw21h"},"components":[{"type":"textnode","content":"♥"}]}]},{"classes":["surprise-container"],"attributes":{"id":"ihl7p7"},"components":[{"classes":["section-top-bar"],"attributes":{"id":"iay5b9"},"components":[{"type":"button","classes":["back-btn","back-button"],"attributes":{"type":"button","id":"is1jmw"},"components":[{"type":"contentEditable","components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["button-icon"],"attributes":{"src":"https://api.iconify.design/lucide-arrow-left.svg?color=%23ffffff","alt":"Back icon","id":"iinejf"}},{"tagName":"span","type":"text","attributes":{"id":"i8o6jv"},"components":[{"type":"textnode","content":"Back to Main Screen"}]}]}]},{"type":"text","classes":["section-label"],"attributes":{"id":"ivpzkl"},"components":[{"type":"textnode","content":"Secret Birthday Vault"}]}]},{"classes":["surprise-layout"],"attributes":{"id":"iw8a07"},"components":[{"classes":["vault-intro"],"attributes":{"id":"iq2q0f"},"components":[{"classes":["vault-label"],"attributes":{"id":"i55t4y"},"components":[{"tagName":"span","classes":["indicator-dot"],"attributes":{"id":"i9p5ge"}},{"type":"textnode","content":"\n              Birthday Verification Required\n            "}]},{"tagName":"h2","type":"heading","classes":["font-display","surprise-heading"],"attributes":{"id":"i476kk"},"components":[{"type":"textnode","content":"Unlock Your Magical Future Plan"}]},{"tagName":"p","type":"text","classes":["surprise-text"],"attributes":{"id":"ivhlgl"},"components":[{"type":"textnode","content":"A beautiful surprise is waiting behind this glowing vault. Enter the correct birthday to open a dreamy plan filled with romance, celebration, and unforgettable moments made especially for you."}]},{"classes":["glass","birthday-form-card"],"attributes":{"id":"ik5kem"},"components":[{"type":"label","classes":["date-label"],"attributes":{"for":"birthday-input","id":"ibh562"},"components":[{"type":"textnode","content":"Birthday Date"}]},{"type":"input","void":true,"classes":["focus:bg-white/12","date-input"],"attributes":{"type":"date","id":"birthday-input","aria-describedby":"birthday-response"}},{"classes":["form-actions"],"attributes":{"id":"i7qdw2"},"components":[{"type":"button","classes":["continue-button"],"attributes":{"type":"button","id":"check-birthday"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Open My Surprise"}]}]},{"tagName":"p","type":"text","classes":["hint-text"],"attributes":{"id":"i4pf01"},"components":[{"type":"textnode","content":"Hint: the vault will only open for 9 October 2002."}]}]},{"classes":["response-area"],"attributes":{"id":"birthday-response","aria-live":"polite"}}]}]},{"classes":["gift-reveal-area"],"attributes":{"id":"i1ix7e"},"components":[{"classes":["gift-stage"],"attributes":{"id":"gift-stage"},"components":[{"classes":["gift-halo"],"attributes":{"id":"iblf1r"}},{"classes":["gift-box"],"attributes":{"id":"gift-box"},"components":[{"classes":["gift-lid"],"attributes":{"id":"i24yvo"},"components":[{"classes":["gift-ribbon-vertical"],"attributes":{"id":"ixdc2z"}},{"classes":["gift-bow-left"],"attributes":{"id":"io4lj2"}},{"classes":["gift-bow-right"],"attributes":{"id":"i5pmcv"}}]},{"classes":["gift-core"],"attributes":{"id":"ix2sng"},"components":[{"classes":["gift-ribbon-vertical"],"attributes":{"id":"ijdpav"}},{"classes":["gift-ribbon-horizontal"],"attributes":{"id":"iw1lqj"}}]}]},{"classes":["hidden-reveal","reveal-message-panel"],"attributes":{"id":"surprise-reveal"},"components":[{"type":"text","classes":["reveal-label"],"attributes":{"id":"is2bh2"},"components":[{"type":"textnode","content":"Unlocked Surprise"}]},{"tagName":"h3","type":"heading","classes":["gold-text","font-display","reveal-heading"],"attributes":{"id":"ie4h4k"},"components":[{"type":"textnode","content":"Our Beautiful Future Plans"}]},{"tagName":"p","type":"text","classes":["typewriter","text-white/88","reveal-message"],"attributes":{"id":"typewriter-message"},"components":[{"type":"textnode","content":"A dreamy chapter is waiting for us: flowers in your hands, your favorite dinner, golden lights, soft music, cake, laughter, and a night that feels like a wish finally coming true."}]},{"classes":["reveal-list"],"attributes":{"id":"ixxkek"},"components":[{"classes":["plan-chip"],"attributes":{"id":"inqnjt"},"components":[{"classes":["plan-icon"],"attributes":{"id":"iysbiu"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://api.iconify.design/lucide-flower-2.svg?color=%23fde8b5","alt":"Flowers icon","loading":"lazy","id":"ir9x33"}}]},{"classes":["plan-copy"],"attributes":{"id":"i8khvf"},"components":[{"tagName":"strong","type":"text","attributes":{"id":"i9s1n3"},"components":[{"type":"textnode","content":"Flowers & a Sweet Arrival"}]},{"tagName":"span","type":"text","attributes":{"id":"iz1wsw"},"components":[{"type":"textnode","content":"You get welcomed with a handpicked bouquet, warm smiles, and that first magical moment of feeling deeply celebrated."}]}]}]},{"classes":["plan-chip"],"attributes":{"id":"ikfltl"},"components":[{"classes":["plan-icon"],"attributes":{"id":"i36rbi"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://api.iconify.design/lucide-utensils-crossed.svg?color=%23fde8b5","alt":"Dinner icon","loading":"lazy","id":"io4hxv"}}]},{"classes":["plan-copy"],"attributes":{"id":"ied2zc"},"components":[{"tagName":"strong","type":"text","attributes":{"id":"isuzaf"},"components":[{"type":"textnode","content":"Your Favorite Dinner Date"}]},{"tagName":"span","type":"text","attributes":{"id":"ixcke5"},"components":[{"type":"textnode","content":"A cozy table, your favorite food, candlelight, and slow conversations that make the whole evening feel soft and romantic."}]}]}]},{"classes":["plan-chip"],"attributes":{"id":"ift1sl"},"components":[{"classes":["plan-icon"],"attributes":{"id":"ix87hb"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://api.iconify.design/lucide-camera.svg?color=%23fde8b5","alt":"Memories icon","loading":"lazy","id":"ika4dk"}}]},{"classes":["plan-copy"],"attributes":{"id":"i08z39"},"components":[{"tagName":"strong","type":"text","attributes":{"id":"irid7w"},"components":[{"type":"textnode","content":"Pretty Photos & Little Keepsakes"}]},{"tagName":"span","type":"text","attributes":{"id":"ivh6u3"},"components":[{"type":"textnode","content":"We will capture the smiles, the details, and the tiny candid moments so this day can stay glowing in memory for a long time."}]}]}]},{"classes":["plan-chip"],"attributes":{"id":"i2h3z8"},"components":[{"classes":["plan-icon"],"attributes":{"id":"i50yeh"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://api.iconify.design/lucide-stars.svg?color=%23fde8b5","alt":"Surprise icon","loading":"lazy","id":"i1sljg"}}]},{"classes":["plan-copy"],"attributes":{"id":"iqqdrd"},"components":[{"tagName":"strong","type":"text","attributes":{"id":"icnve4"},"components":[{"type":"textnode","content":"One More Secret Surprise"}]},{"tagName":"span","type":"text","attributes":{"id":"igqlni"},"components":[{"type":"textnode","content":"And before the night ends, there will be one extra heartfelt surprise made to make your birthday feel even more unforgettable."}]}]}]}]}]},{"classes":["effects-layer"],"attributes":{"id":"effects-layer"}}]}]}]}]}]}]},{"type":"script","attributes":{"id":"idhzw5"},"components":[{"type":"textnode","content":"\n    const appRoot = document.querySelector('[data-js=\"birthday-app\"]') || document;\n    const sections = Array.from(appRoot.querySelectorAll('.section-screen'));\n    const navCards = appRoot.querySelectorAll('.nav-card');\n    const backButtons = appRoot.querySelectorAll('.back-btn');\n    const birthdayInput = document.getElementById('birthday-input');\n    const checkBirthdayBtn = document.getElementById('check-birthday');\n    const birthdayResponse = document.getElementById('birthday-response');\n    const giftBox = document.getElementById('gift-box');\n    const revealPanel = document.getElementById('surprise-reveal');\n    const effectsLayer = document.getElementById('effects-layer');\n    const giftStage = document.getElementById('gift-stage');\n    const typewriterMessage = document.getElementById('typewriter-message');\n\n    const correctBirthday = '2002-10-09';\n    const funnyResponses = [\n      'Oops, that is not the birthday this fairytale is waiting for.',\n      'Close your eyes, think of 9 October 2002, and try again.',\n      'Even the stars say that date is wrong.',\n      'The cake is shaking its head. Try the real birthday.',\n      'That date belongs to another love story.',\n      'Access denied by flowers, sparkles, and destiny.',\n      'The vault wants the exact birthday magic.',\n      'Nope. Try the birthday that makes today special.',\n      'Almost poetic, but still not the right date.',\n      'Hint: October is doing a lot of the work here.'\n    ];\n\n    const futureMessages = [\n      'A dreamy chapter is waiting for us: flowers in your hands, your favorite dinner, golden lights, soft music, cake, laughter, and a night that feels like a wish finally coming true.',\n      'Then comes a slow evening walk, pretty pictures together, heartfelt surprises, and one memory after another turning your birthday into something unforgettable.',\n      'And after all of that, the best part remains simple: giving you a day full of love, effort, softness, and beautiful moments made only for you.'\n    ];\n\n    const sectionEnterClasses = {\n      hero: 'is-hero-enter',\n      love: 'is-love-enter',\n      photos: 'is-photos-enter',\n      wishes: 'is-wishes-enter',\n      surprise: 'is-surprise-enter'\n    };\n\n    const revealConfigs = {\n      hero: [\n        { selector: '.hero-intro', effect: 'reveal-side' },\n        { selector: '.navigation-card', effect: 'reveal-float', stagger: 0.12 }\n      ],\n      love: [\n        { selector: '.section-top-bar', effect: 'reveal-side' },\n        { selector: '.letter-card', effect: 'reveal-show' },\n        { selector: '.quote-panel', effect: 'reveal-pop', delay: 0.1 },\n        { selector: '.memory-note', effect: 'reveal-float', stagger: 0.12, delay: 0.18 }\n      ],\n      photos: [\n        { selector: '.section-top-bar', effect: 'reveal-side' },\n        { selector: '.photo-header', effect: 'reveal-show', delay: 0.05 },\n        { selector: '.photo-string-row', effect: 'reveal-show', delay: 0.12 },\n        { selector: '.polaroid-card', effect: 'reveal-pop', stagger: 0.1, delay: 0.18 }\n      ],\n      wishes: [\n        { selector: '.section-top-bar', effect: 'reveal-side' },\n        { selector: '.wishes-header', effect: 'reveal-show', delay: 0.05 },\n        { selector: '.wish-card', effect: 'reveal-float', stagger: 0.08, delay: 0.15 }\n      ],\n      surprise: [\n        { selector: '.section-top-bar', effect: 'reveal-side' },\n        { selector: '.vault-intro', effect: 'reveal-show', delay: 0.05 },\n        { selector: '.gift-reveal-area', effect: 'reveal-pop', delay: 0.14 }\n      ]\n    };\n\n    let currentSection = document.getElementById('hero');\n    let wrongAttemptIndex = 0;\n    let surpriseUnlocked = false;\n    let futureMessageIndex = 0;\n    let transitionLock = false;\n\n    function clearSectionAnimationClasses(section) {\n      Object.values(sectionEnterClasses).forEach(cls => section.classList.remove(cls));\n    }\n\n    function markRevealItems(section) {\n      section.querySelectorAll('.section-reveal-item').forEach(el => {\n        el.classList.remove('section-reveal-item', 'reveal-show', 'reveal-float', 'reveal-pop', 'reveal-side');\n        el.style.removeProperty('--reveal-delay');\n      });\n\n      const config = revealConfigs[section.id] || [];\n      config.forEach(group => {\n        const nodes = Array.from(section.querySelectorAll(group.selector));\n        nodes.forEach((node, index) => {\n          const delay = (group.delay || 0) + (group.stagger || 0) * index;\n          node.classList.add('section-reveal-item');\n          if (group.effect && group.effect !== 'reveal-show') {\n            node.classList.add(group.effect);\n          }\n          node.style.setProperty('--reveal-delay', `${delay}s`);\n        });\n      });\n    }\n\n    function playRevealAnimation(section) {\n      clearSectionAnimationClasses(section);\n      markRevealItems(section);\n      section.classList.add(sectionEnterClasses[section.id] || 'is-hero-enter');\n\n      requestAnimationFrame(() => {\n        requestAnimationFrame(() => {\n          section.querySelectorAll('.section-reveal-item').forEach(el => el.classList.add('reveal-show'));\n        });\n      });\n\n      if (section.id === 'love') {\n        launchSectionPetals(section, ['#f4bfd4', '#dcbef7', '#f7dfab'], 12);\n      }\n      if (section.id === 'photos') {\n        launchSectionBursts(section, 8, ['#ffffff', '#f7e6bb', '#efd2e6']);\n      }\n      if (section.id === 'wishes') {\n        launchSectionConfetti(section, 14);\n      }\n      if (section.id === 'surprise') {\n        giftStage.classList.remove('section-spotlight');\n        void giftStage.offsetWidth;\n        giftStage.classList.add('section-spotlight');\n        launchSectionBursts(section, 10, ['#ffe7a8', '#ffd0e4', '#d9c4ff']);\n      }\n    }\n\n    function showSection(targetId) {\n      const nextSection = document.getElementById(targetId);\n      if (!nextSection || nextSection === currentSection || transitionLock) return;\n      transitionLock = true;\n\n      clearSectionAnimationClasses(currentSection);\n      currentSection.classList.remove('screen-enter');\n      currentSection.classList.add('screen-exit');\n\n      setTimeout(() => {\n        currentSection.classList.remove('active', 'screen-exit');\n        nextSection.classList.add('active', 'screen-enter');\n        playRevealAnimation(nextSection);\n        currentSection = nextSection;\n\n        setTimeout(() => {\n          nextSection.classList.remove('screen-enter');\n          window.scrollTo({ top: 0, behavior: 'smooth' });\n          transitionLock = false;\n        }, 720);\n      }, 320);\n    }\n\n    function createRipple(event, element) {\n      const circle = document.createElement('span');\n      const diameter = Math.max(element.clientWidth, element.clientHeight);\n      const radius = diameter / 2;\n      const rect = element.getBoundingClientRect();\n\n      circle.className = 'ripple';\n      circle.style.width = `${diameter}px`;\n      circle.style.height = `${diameter}px`;\n      circle.style.left = `${event.clientX - rect.left - radius}px`;\n      circle.style.top = `${event.clientY - rect.top - radius}px`;\n\n      const existingRipple = element.querySelector('.ripple');\n      if (existingRipple) existingRipple.remove();\n\n      element.appendChild(circle);\n      setTimeout(() => circle.remove(), 700);\n    }\n\n    function launchSectionBursts(section, count = 8, palette = ['#ffffff']) {\n      for (let i = 0; i < count; i++) {\n        const burst = document.createElement('span');\n        burst.className = 'section-burst';\n        burst.style.left = `${8 + Math.random() * 84}%`;\n        burst.style.top = `${8 + Math.random() * 72}%`;\n        burst.style.background = `radial-gradient(circle, ${palette[Math.floor(Math.random() * palette.length)]}, rgba(255,255,255,0))`;\n        burst.style.animationDelay = `${Math.random() * .25}s`;\n        section.appendChild(burst);\n        setTimeout(() => burst.remove(), 1300);\n      }\n    }\n\n    function launchSectionPetals(section, palette, count = 12) {\n      for (let i = 0; i < count; i++) {\n        const petal = document.createElement('span');\n        petal.className = 'section-petal';\n        petal.style.left = `${6 + Math.random() * 88}%`;\n        petal.style.bottom = `${-2 + Math.random() * 10}%`;\n        petal.style.background = palette[Math.floor(Math.random() * palette.length)];\n        petal.style.setProperty('--petal-x', `${-32 + Math.random() * 64}px`);\n        petal.style.animationDelay = `${Math.random() * .3}s`;\n        section.appendChild(petal);\n        setTimeout(() => petal.remove(), 3000);\n      }\n    }\n\n    function launchSectionConfetti(section, count = 18) {\n      const colors = ['#f7d98d', '#f5b8cf', '#d3b5f2', '#fff7dc', '#ffc4d8', '#ffeab3'];\n      for (let i = 0; i < count; i++) {\n        const piece = document.createElement('span');\n        piece.className = 'confetti-piece';\n        piece.style.left = `${Math.random() * 100}%`;\n        piece.style.top = `${-8 - Math.random() * 20}%`;\n        piece.style.background = colors[Math.floor(Math.random() * colors.length)];\n        piece.style.transform = `rotate(${Math.random() * 360}deg)`;\n        piece.style.animationDelay = `${Math.random() * .25}s`;\n        section.appendChild(piece);\n        setTimeout(() => piece.remove(), 2800);\n      }\n    }\n\n    navCards.forEach(card => {\n      card.addEventListener('click', event => {\n        createRipple(event, card);\n        const target = card.getAttribute('data-target');\n        setTimeout(() => showSection(target), 110);\n      });\n    });\n\n    backButtons.forEach(btn => {\n      btn.addEventListener('click', event => {\n        createRipple(event, btn);\n        setTimeout(() => showSection('hero'), 100);\n      });\n    });\n\n    function randomFunnyMessage() {\n      const message = funnyResponses[wrongAttemptIndex % funnyResponses.length];\n      wrongAttemptIndex += 1;\n      return message;\n    }\n\n    function launchConfetti() {\n      const colors = ['#f7d98d', '#f5b8cf', '#d3b5f2', '#ffffff', '#ffc4d8', '#ffeab3'];\n      for (let i = 0; i < 36; i++) {\n        const piece = document.createElement('span');\n        piece.className = 'confetti-piece';\n        piece.style.left = `${Math.random() * 100}%`;\n        piece.style.top = `${-10 - Math.random() * 20}%`;\n        piece.style.background = colors[Math.floor(Math.random() * colors.length)];\n        piece.style.transform = `rotate(${Math.random() * 360}deg)`;\n        piece.style.animationDelay = `${Math.random() * .35}s`;\n        effectsLayer.appendChild(piece);\n        setTimeout(() => piece.remove(), 3000);\n      }\n    }\n\n    function launchFireworks() {\n      const positions = [\n        { x: 18, y: 24 },\n        { x: 78, y: 26 },\n        { x: 50, y: 18 },\n        { x: 28, y: 52 },\n        { x: 72, y: 56 },\n        { x: 44, y: 40 }\n      ];\n      positions.forEach((pos, idx) => {\n        const spark = document.createElement('span');\n        spark.className = 'firework';\n        spark.style.left = `${pos.x}%`;\n        spark.style.top = `${pos.y}%`;\n        spark.style.animationDelay = `${idx * .08}s`;\n        effectsLayer.appendChild(spark);\n        setTimeout(() => spark.remove(), 1300);\n      });\n    }\n\n    function launchHearts() {\n      for (let i = 0; i < 12; i++) {\n        const heart = document.createElement('span');\n        heart.textContent = '♥';\n        heart.className = 'heart-float';\n        heart.style.left = `${10 + Math.random() * 80}%`;\n        heart.style.bottom = `${Math.random() * 10}%`;\n        heart.style.fontSize = `${18 + Math.random() * 18}px`;\n        heart.style.color = ['#ffd1e5', '#f8e3a5', '#e4ccff'][Math.floor(Math.random() * 3)];\n        heart.style.opacity = '.34';\n        heart.style.animationDuration = `${6.8 + Math.random() * 2.4}s`;\n        heart.style.animationDelay = `${Math.random() * .6}s`;\n        effectsLayer.appendChild(heart);\n        setTimeout(() => heart.remove(), 7600);\n      }\n    }\n\n    function launchGlowTrails() {\n      for (let i = 0; i < 10; i++) {\n        const trail = document.createElement('span');\n        trail.className = 'glow-trail';\n        trail.style.left = `${8 + Math.random() * 84}%`;\n        trail.style.bottom = `${2 + Math.random() * 12}%`;\n        trail.style.animationDelay = `${Math.random() * .6}s`;\n        trail.style.animationDuration = `${4.2 + Math.random() * 1.2}s`;\n        effectsLayer.appendChild(trail);\n        setTimeout(() => trail.remove(), 5200);\n      }\n    }\n\n    function cycleFutureMessages() {\n      if (!typewriterMessage) return;\n      setInterval(() => {\n        if (!surpriseUnlocked) return;\n        futureMessageIndex = (futureMessageIndex + 1) % futureMessages.length;\n        typewriterMessage.classList.remove('typewriter');\n        void typewriterMessage.offsetWidth;\n        typewriterMessage.textContent = futureMessages[futureMessageIndex];\n        typewriterMessage.classList.add('typewriter');\n      }, 5000);\n    }\n\n    function unlockSurprise() {\n      if (surpriseUnlocked) return;\n      surpriseUnlocked = true;\n      birthdayResponse.textContent = 'Birthday verified for 9 October 2002. Opening your beautiful surprise...';\n      birthdayResponse.className = 'response-area';\n      giftBox.classList.add('gift-open');\n      revealPanel.classList.add('show');\n      launchConfetti();\n      setTimeout(launchFireworks, 180);\n      setTimeout(launchHearts, 300);\n      setTimeout(launchGlowTrails, 420);\n      giftStage.classList.add('pulse-glow');\n    }\n\n    checkBirthdayBtn.addEventListener('click', () => {\n      const entered = birthdayInput.value;\n      if (!entered) {\n        birthdayResponse.textContent = 'Please enter the birthday first so the vault can check it.';\n        birthdayResponse.className = 'response-area';\n        return;\n      }\n\n      if (entered === correctBirthday) {\n        unlockSurprise();\n      } else {\n        birthdayResponse.textContent = randomFunnyMessage();\n        birthdayResponse.className = 'response-area';\n      }\n    });\n\n    birthdayInput.addEventListener('keydown', e => {\n      if (e.key === 'Enter') {\n        e.preventDefault();\n        checkBirthdayBtn.click();\n      }\n    });\n\n    playRevealAnimation(currentSection);\n    cycleFutureMessages();\n  "}]}],"doctype":"<!DOCTYPE html>","head":{"type":"head","components":[{"tagName":"meta","void":true,"attributes":{"charset":"UTF-8"}},{"tagName":"meta","void":true,"attributes":{"name":"viewport","content":"width=device-width, initial-scale=1.0"}},{"tagName":"title","type":"text","components":[{"type":"textnode","content":"Birthday Surprise"}]},{"tagName":"link","void":true,"attributes":{"rel":"preconnect","href":"https://fonts.googleapis.com"}},{"tagName":"link","void":true,"attributes":{"rel":"preconnect","href":"https://fonts.gstatic.com","crossorigin":""}},{"tagName":"link","void":true,"attributes":{"href":"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap","rel":"stylesheet"}}]},"docEl":{"tagName":"html","attributes":{"lang":"en"}}},"id":"fwiJBuhrVEXNAUpE","minHeight":"500px"}],"id":"MNrOyYSEQEsdzBUh"}],"symbols":[],"custom":{"projectType":"web","id":""}}